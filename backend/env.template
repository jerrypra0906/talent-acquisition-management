# Application Configuration
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:4001
CANDIDATE_PORTAL_URL=http://localhost:4002

# Database Configuration
# Default password from docker-compose.yml: tas_secure_password_change_this
# If using Docker, change host from 'localhost' to 'postgres'
DATABASE_URL=postgresql://tas_user:tas_secure_password_change_this@localhost:5432/tas_db?schema=public

# Redis Configuration
# Default password from docker-compose.yml: redis_secure_password_change_this
# If using Docker, change host from 'localhost' to 'redis'
# Format: redis://:password@host:port
REDIS_URL=redis://:redis_secure_password_change_this@localhost:6379
REDIS_PASSWORD=redis_secure_password_change_this
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-characters-long-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption Configuration (AES-256 requires 32 characters)
ENCRYPTION_KEY=your-32-character-encryption-key-change-this-in-production

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=KPN Talent Acquisition
SMTP_FROM_EMAIL=noreply@kpn.com

# WhatsApp Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,xls,xlsx
UPLOAD_DIR=./uploads

# AWS S3 Configuration (for production)
USE_S3=false
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=kpn-tas-documents

# Security Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX=5
ACCOUNT_LOCKOUT_THRESHOLD=5

# CORS Configuration
CORS_ORIGIN=http://localhost:3001,http://localhost:3002

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_DIR=./logs

