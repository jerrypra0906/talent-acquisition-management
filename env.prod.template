# Production Environment Configuration Template
# Copy this file to .env.prod and update with actual values
# NEVER commit .env.prod to version control

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=tas_user
POSTGRES_PASSWORD=taskpn@2025
POSTGRES_DB=tas_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================
# Redis Configuration
# ============================================
# Generate a secure Redis password
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REDIS_PASSWORD=CHANGE_THIS_TO_SECURE_REDIS_PASSWORD
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# Application Configuration
# ============================================
NODE_ENV=production
PORT=4000
API_BASE_URL=https://api.yourdomain.com

# ============================================
# Frontend URLs (Update with your domain)
# ============================================
FRONTEND_URL=https://admin.yourdomain.com
CANDIDATE_PORTAL_URL=https://careers.yourdomain.com
CORS_ORIGIN=https://admin.yourdomain.com,https://careers.yourdomain.com
CORS_CREDENTIALS=true

# ============================================
# Database Connection String
# ============================================
DATABASE_URL=postgresql://tas_user:taskpn@2025@postgres:5432/tas_db?schema=public&pool_timeout=0&connection_limit=20

# ============================================
# Redis Connection String
# ============================================
REDIS_URL=redis://:CHANGE_THIS_TO_SECURE_REDIS_PASSWORD@redis:6379

# ============================================
# JWT Configuration
# ============================================
# Generate secure JWT secrets (64+ characters)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_SECURE_JWT_SECRET_MIN_64_CHARACTERS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_SECURE_REFRESH_SECRET_MIN_64_CHARACTERS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Encryption Configuration
# ============================================
# MUST be exactly 32 characters (AES-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=CHANGE_THIS_TO_32_CHARACTER_ENCRYPTION_KEY

# ============================================
# Email Configuration (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@yourdomain.com
SMTP_PASSWORD=CHANGE_THIS_TO_SMTP_PASSWORD
SMTP_FROM_NAME=KPN Talent Acquisition
SMTP_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# WhatsApp Configuration (Twilio - Optional)
# ============================================
TWILIO_ACCOUNT_SID=CHANGE_THIS_TO_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=CHANGE_THIS_TO_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ============================================
# File Upload Configuration
# ============================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,xls,xlsx
UPLOAD_DIR=./uploads

# ============================================
# AWS S3 Configuration (for production file storage)
# ============================================
USE_S3=false
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=CHANGE_THIS_TO_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=CHANGE_THIS_TO_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET=kpn-tas-documents

# ============================================
# Security Configuration
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX=5
ACCOUNT_LOCKOUT_THRESHOLD=5

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info
LOG_FILE_DIR=./logs

# ============================================
# Next.js Public API URL (for frontend apps)
# ============================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# ============================================
# Default Password Configuration (for new users)
# ============================================
# Generate secure default password for new candidates/users
# Use: node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
DEFAULT_USER_PASSWORD=CHANGE_THIS_TO_SECURE_DEFAULT_PASSWORD
DEFAULT_CANDIDATE_PASSWORD=CHANGE_THIS_TO_SECURE_DEFAULT_PASSWORD

